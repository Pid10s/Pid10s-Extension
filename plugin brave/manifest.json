{
  "key": "",
  "manifest_version": 3,
  "name": "Desacoplador de Pid10s",
  "version": "1.2",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "storage",
    "nativeMessaging"
  ],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://*.twitch.tv/*",
    "http://127.0.0.1:10101/*",
    "http://localhost:10101/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": "icon.png",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://*.twitch.tv/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "style.css"
      ]
    },
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://*.twitch.tv/*"
      ],
      "js": [
        "main.js"
      ],
      "world": "MAIN"
    }
  ],
  "commands": {
    "volume_down": {
      "suggested_key": {
        "default": "Ctrl+Shift+Comma",
        "mac": "Command+Shift+Comma"
      },
      "description": "Bajar volumen (YouTube y Twitch)",
      "global": true
    },
    "volume_up": {
      "suggested_key": {
        "default": "Ctrl+Shift+Period",
        "mac": "Command+Shift+Period"
      },
      "description": "Subir volumen (YouTube y Twitch)",
      "global": true
    },
    "toggle_pip_shortcut": {
      "suggested_key": {
        "default": "Alt+P",
        "mac": "Alt+P"
      },
      "description": "Activar la extensión (PiP)"
    }
  }
}